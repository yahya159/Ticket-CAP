# Ignore rules for the monolithic CAP app

# Dependencies
node_modules/

# Build output
gen/
dist/
build/

# SQLite database (runtime artifact - seed via cds deploy)
*.db
*.db-journal
*.db-wal
*.db-shm
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm

# CDS build cache
.cds-build/
.build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/settings.json
.idea/
*.iml
*.swp
*.swo

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# Test coverage
coverage/
.nyc_output/
