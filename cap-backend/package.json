{
  "name": "cap-backend",
  "version": "1.0.0",
  "description": "SAP CAP OData v4 backend – Performance Management Platform",
  "main": "server.js",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "dev:web": "npm run dev --prefix app/frontend",
    "dev:all": "node scripts/dev-all.js",
    "build:web": "npm run build --prefix app/frontend",
    "build": "npm run build:web && cds build",
    "lint": "eslint .",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@cap-js/mcp-server": "^0.0.5",
    "@cap-js/sqlite": "^1",
    "@sap/cds": "^8"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8",
    "@types/jest": "^30.0.0",
    "axios": "^1.13.5",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "chai-subset": "^1.6.0",
    "eslint": "^9.39.3",
    "jest": "^29.7.0"
  },
  "cds": {
    "requires": {
      "auth": "mocked",
      "db": {
        "kind": "sqlite",
        "credentials": {
          "database": "db/performance.db"
        }
      }
    }
  }
}
