# Backend Environment Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# Database Configuration
# =============================================================================
# SQLite is used by default for development (configured in .cdsrc.json)
# For production, consider PostgreSQL or SAP HANA

# PostgreSQL Example (uncomment and configure in .cdsrc.json)
# DB_KIND=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=performance_db
# DB_USER=dbuser
# DB_PASSWORD=your_secure_password

# SAP HANA Example
# DB_KIND=hana
# DB_HOST=hana.example.com
# DB_PORT=30015
# DB_USER=SYSTEM
# DB_PASSWORD=your_secure_password

# =============================================================================
# Server Configuration
# =============================================================================

# Server port (default: 4004)
PORT=4004

# Server host (default: localhost)
# HOST=0.0.0.0

# Node environment (development, production)
NODE_ENV=development

# =============================================================================
# Authentication & Security
# =============================================================================

# JWT Secret Key (REQUIRED for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=your_secret_key_here

# JWT Token Expiration (e.g., 1h, 24h, 7d)
# JWT_EXPIRATION=24h

# JWT Refresh Token Expiration
# JWT_REFRESH_EXPIRATION=7d

# CSRF Protection (currently disabled in .cdsrc.json)
# CSRF_ENABLED=false

# CORS Allowed Origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,https://yourapp.com

# =============================================================================
# OData Configuration
# =============================================================================

# OData version (v2 or v4)
ODATA_VERSION=v4

# Maximum page size for OData queries
# ODATA_MAX_PAGE_SIZE=1000

# Enable OData batch requests
# ODATA_BATCH_ENABLED=true

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (error, warn, info, debug, trace)
LOG_LEVEL=info

# Log format (json, text)
# LOG_FORMAT=text

# Enable request logging
# LOG_REQUESTS=true

# Log file path (leave empty to log to console only)
# LOG_FILE_PATH=./logs/app.log

# =============================================================================
# External Services
# =============================================================================

# StraTIME Integration
# STRATIME_API_URL=https://stratime.example.com/api
# STRATIME_API_KEY=your_api_key
# STRATIME_ENABLED=false

# Email Service (for notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your_smtp_password
# EMAIL_FROM=noreply@example.com

# File Storage (for attachments)
# STORAGE_TYPE=local
# STORAGE_PATH=./uploads
# STORAGE_MAX_SIZE=10485760

# S3 Storage Example
# STORAGE_TYPE=s3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=performance-dashboard-uploads

# =============================================================================
# Performance & Caching
# =============================================================================

# Enable caching
# CACHE_ENABLED=true

# Cache TTL (in seconds)
# CACHE_TTL=3600

# Redis cache (optional)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# =============================================================================
# Rate Limiting
# =============================================================================

# Enable rate limiting
# RATE_LIMIT_ENABLED=true

# Maximum requests per window
# RATE_LIMIT_MAX=100

# Time window (in milliseconds)
# RATE_LIMIT_WINDOW=60000

# =============================================================================
# Monitoring & Analytics
# =============================================================================

# Application Insights (Azure)
# APPINSIGHTS_INSTRUMENTATIONKEY=

# Sentry Error Tracking
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# New Relic
# NEW_RELIC_LICENSE_KEY=
# NEW_RELIC_APP_NAME=SAP Performance Dashboard

# =============================================================================
# Background Jobs
# =============================================================================

# Enable scheduled jobs
# JOBS_ENABLED=true

# Cron schedule for data cleanup (daily at 2 AM)
# JOB_CLEANUP_SCHEDULE=0 2 * * *

# Cron schedule for notification digest (every hour)
# JOB_NOTIFICATIONS_SCHEDULE=0 * * * *

# =============================================================================
# Development Only
# =============================================================================

# Enable debug mode
# DEBUG=true

# Enable SQL query logging
# SQL_DEBUG=false

# Mock external services
# MOCK_EXTERNAL_SERVICES=false

# Seed database on startup
# SEED_DATABASE=false

# =============================================================================
# Production Deployment
# =============================================================================
# For production deployments, ensure these are set:

# Example production configuration:
# NODE_ENV=production
# PORT=8080
# DB_KIND=postgres
# DB_HOST=prod-db.example.com
# DB_NAME=performance_prod
# JWT_SECRET=<generate-secure-random-key>
# CORS_ORIGINS=https://dashboard.yourcompany.com
# LOG_LEVEL=warn
# CACHE_ENABLED=true
# RATE_LIMIT_ENABLED=true
# SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# Notes
# =============================================================================
# - Never commit .env files with sensitive data to version control
# - Use .env.local for local overrides (automatically gitignored)
# - For production, use environment variables from your hosting platform
# - Restart the server after changing environment variables
# - Database configuration is primarily managed in .cdsrc.json
