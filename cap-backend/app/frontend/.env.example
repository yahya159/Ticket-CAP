# Frontend Environment Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# OData Service Endpoints
# =============================================================================
# In development, Vite proxy handles /odata/v4 requests automatically.
# In production, set this to your deployed backend URL if you want absolute service URLs.
VITE_ODATA_BASE_URL=/odata/v4

# =============================================================================
# Application Configuration
# =============================================================================

# Application Title (displayed in browser tab and header)
# VITE_APP_TITLE=SAP Performance Dashboard

# Application Environment (development, staging, production)
# VITE_APP_ENV=development

# Enable debug mode (shows additional logging in console)
# VITE_DEBUG=false

# =============================================================================
# Feature Flags
# =============================================================================
# Enable or disable specific features

# Enable experimental features
# VITE_FEATURE_EXPERIMENTAL=false

# Enable analytics tracking
# VITE_FEATURE_ANALYTICS=false

# Enable performance monitoring
# VITE_FEATURE_PERFORMANCE_MONITORING=false

# =============================================================================
# Authentication Configuration
# =============================================================================

# JWT Token expiration time (in seconds)
# VITE_AUTH_TOKEN_EXPIRY=3600

# Session timeout warning (in seconds before expiry)
# VITE_AUTH_SESSION_WARNING=300

# =============================================================================
# API Configuration
# =============================================================================

# API request timeout (in milliseconds)
# VITE_API_TIMEOUT=30000

# Maximum number of retry attempts for failed requests
# VITE_API_MAX_RETRIES=3

# Delay between retry attempts (in milliseconds)
# VITE_API_RETRY_DELAY=1000

# =============================================================================
# UI Configuration
# =============================================================================

# Default theme (light, dark, system)
# VITE_DEFAULT_THEME=system

# Default language (en, fr)
# VITE_DEFAULT_LANGUAGE=en

# Items per page for paginated lists
# VITE_DEFAULT_PAGE_SIZE=20

# Maximum file upload size (in MB)
# VITE_MAX_FILE_UPLOAD_SIZE=10

# =============================================================================
# External Services
# =============================================================================

# StraTIME integration endpoint (for time export)
# VITE_STRATIME_API_URL=

# StraTIME API key
# VITE_STRATIME_API_KEY=

# =============================================================================
# Development Only
# =============================================================================

# Mock API responses (useful for frontend development without backend)
# VITE_USE_MOCK_API=false

# Show React Query DevTools
# VITE_SHOW_DEVTOOLS=true

# Enable verbose logging
# VITE_VERBOSE_LOGGING=false

# =============================================================================
# Production Deployment
# =============================================================================
# For production deployments, set these variables in your hosting platform
# (Vercel, Netlify, AWS, etc.) or CI/CD pipeline.

# Example production configuration:
# VITE_ODATA_CORE_URL=https://api.yourcompany.com/odata/v4/CoreService
# VITE_ODATA_USER_URL=https://api.yourcompany.com/odata/v4/UserService
# VITE_ODATA_TICKET_URL=https://api.yourcompany.com/odata/v4/TicketService
# VITE_ODATA_TIME_URL=https://api.yourcompany.com/odata/v4/TimeService
# VITE_APP_ENV=production
# VITE_DEBUG=false
# VITE_FEATURE_ANALYTICS=true

# =============================================================================
# Notes
# =============================================================================
# - All variables must be prefixed with VITE_ to be exposed to the frontend
# - Changes to .env require restarting the Vite dev server
# - Never commit .env files with sensitive data to version control
# - Use .env.local for local overrides (automatically gitignored)
