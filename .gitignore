# Root-level .gitignore for SAP Performance Dashboard

# Dependencies
node_modules/

# Build outputs
dist/
gen/
build/

# Environment files
.env
.env.local
.env.*.local

# Database files
*.db
*.db-journal
*.db-wal
*.db-shm

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# IDE
.vscode/settings.json
.idea/
*.iml

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# LaTeX build artifacts (if documentation is added back)
*.aux
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.out
*.pdf

# Test coverage
coverage/
.nyc_output/

# Misc
.DS_Store
Thumbs.db
